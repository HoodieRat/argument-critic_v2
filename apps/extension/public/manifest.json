{
  "manifest_version": 3,
  "name": "Argument Critic",
  "version": "1.0.0",
  "key": "",
  "description": "Local Copilot-powered argument companion with advisor-style critique and persistent question tracking.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Argument Critic"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "welcome.html",
        "welcome.js",
        "sidepanel.html",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "cropOverlay.js"
      ],
      "run_at": "document_idle"
    }
  ]
}