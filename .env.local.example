# Copy this file to .env.local for local maintainer-only runtime settings.
# End users should not need to edit this.

# Optional maintainer override: switch the default sign-in path away from the
# CLI-backed GitHub sign-in flow.
# ARGUMENT_CRITIC_GITHUB_LOGIN_AUTH_METHOD=oauth-device

# Enable built-in GitHub browser sign-in for this build when the override above
# is set to oauth-device.
ARGUMENT_CRITIC_GITHUB_OAUTH_CLIENT_ID=